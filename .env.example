# AI Provider 配置
# Provider: claude | openai | custom
AI_PROVIDER=claude
AI_API_KEY=
AI_MODEL=claude-sonnet-4-6

# 自定义 API Base URL
# DeepSeek (OpenAI 格式):   https://api.deepseek.com
# 小米 (OpenAI 格式):      https://token-plan-cn.xiaomimimo.com/v1
AI_BASE_URL=

# SkillsMP API (从 https://skillsmp.com 获取)
SKILLSMP_API_KEY=

# App
LOG_LEVEL=info
NODE_ENV=development
