# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# GitHub API Tokens (可选，用于安全扫描)
GITHUB_TOKEN_1=
GITHUB_TOKEN_2=
GITHUB_TOKEN_3=

# SQLite 数据库 (路径相对于 packages/shared/prisma/)
DATABASE_URL="file:./dev.db"

# AI Provider 配置
# Provider: claude | openai | deepseek | custom
AI_PROVIDER=claude
AI_API_KEY=
AI_MODEL=claude-sonnet-4-6

# 自定义 API Base URL
# DeepSeek (OpenAI 格式):   https://api.deepseek.com
# 小米 (Anthropic 格式):    https://token-plan-cn.xiaomimimo.com/anthropic
AI_BASE_URL=

# 小米模型示例:
#   AI_PROVIDER=claude
#   AI_API_KEY=tp-xxx
#   AI_MODEL=mimo-v2.5-pro
#   AI_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic

# Anthropic 官方 API (当 AI_PROVIDER=claude 且未设 AI_BASE_URL 时)
ANTHROPIC_API_KEY=

# SkillsMP API
SKILLSMP_API_KEY=

# App
LOG_LEVEL=info
NODE_ENV=development
